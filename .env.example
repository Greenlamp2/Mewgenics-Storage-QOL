# Remote PostgreSQL connection for the Gift feature.
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit credentials.

# Option A — full connection URL (takes priority if set)
# DATABASE_URL=postgres://user:password@host:5432/mewgenics

# Option B — individual variables
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mewgenics
DB_USER=your_user
DB_PASSWORD=your_password

